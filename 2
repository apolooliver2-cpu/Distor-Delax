name: Build VST3
on: [push]
jobs:
  build:
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
      - name: Build
        run: |
          cmake -B build
          cmake --build build --config Release
      - name: Upload
        uses: actions/upload-artifact@v4
        with:
          name: Saturn-Tribal-Plugin
          path: build/SaturnTribal_artefacts/Release/VST3/
